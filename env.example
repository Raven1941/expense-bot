# Copy this file to .env and fill in your values
# On Railway.app — set these in the "Variables" tab

# Required: your Telegram bot token from @BotFather
BOT_TOKEN=your_telegram_bot_token_here

# Optional: OCR.space API key (free at https://ocr.space/ocrapi)
# Leave as 'helloworld' for demo key (limited requests)
# Register free to get 25,000 requests/month
OCR_API_KEY=helloworld
